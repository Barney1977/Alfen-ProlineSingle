  "flow": {
    "triggers": [
      {
        "id": "charging_started",
        "title": {
          "en": "Charging started",
          "nl": "Laden gestart"
        },
        "hint": {
          "en": "Triggered when the EV transitions to an active charging state (C1 or C2).",
          "nl": "Wordt geactiveerd als het voertuig begint met laden (C1 of C2)."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          }
        ]
      },
      {
        "id": "charging_stopped",
        "title": {
          "en": "Charging stopped",
          "nl": "Laden gestopt"
        },
        "hint": {
          "en": "Triggered when the EV transitions out of an active charging state.",
          "nl": "Wordt geactiveerd als het voertuig stopt met laden."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          }
        ]
      },
      {
        "id": "car_connected",
        "title": {
          "en": "Car connected",
          "nl": "Auto aangesloten"
        },
        "hint": {
          "en": "Triggered when a vehicle is plugged in (state B or C).",
          "nl": "Wordt geactiveerd als een voertuig wordt aangesloten (status B of C)."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          }
        ]
      },
      {
        "id": "car_disconnected",
        "title": {
          "en": "Car disconnected",
          "nl": "Auto losgekoppeld"
        },
        "hint": {
          "en": "Triggered when a vehicle is unplugged (state A).",
          "nl": "Wordt geactiveerd als een voertuig wordt losgekoppeld (status A)."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          }
        ]
      },
      {
        "id": "charging_paused",
        "title": {
          "en": "Charging paused",
          "nl": "Laden gepauzeerd"
        },
        "hint": {
          "en": "Triggered when charging is paused (current set to 3 A).",
          "nl": "Wordt geactiveerd als laden wordt gepauzeerd (stroom ingesteld op 3 A)."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          }
        ]
      },
      {
        "id": "charging_resumed",
        "title": {
          "en": "Charging resumed",
          "nl": "Laden hervat"
        },
        "hint": {
          "en": "Triggered when charging resumes after a pause.",
          "nl": "Wordt geactiveerd als laden wordt hervat na een pauze."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "is_charging",
        "title": {
          "en": "Charger !{{is|is not}} actively charging",
          "nl": "Lader is !{{aan het laden|niet aan het laden}}"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          }
        ]
      },
      {
        "id": "is_car_connected",
        "title": {
          "en": "Car !{{is|is not}} connected",
          "nl": "Auto !{{is|is niet}} aangesloten"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          }
        ]
      },
      {
        "id": "is_paused",
        "title": {
          "en": "Charging !{{is|is not}} paused",
          "nl": "Laden is !{{gepauzeerd|niet gepauzeerd}}"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "update_grid_current",
        "title": {
          "en": "Update grid current measurement",
          "nl": "Actueel netstroom meting doorgeven"
        },
        "titleFormatted": {
          "en": "Update grid current: L1 [[current_l1]] A, L2 [[current_l2]] A, L3 [[current_l3]] A",
          "nl": "Netstroom bijwerken: L1 [[current_l1]] A, L2 [[current_l2]] A, L3 [[current_l3]] A"
        },
        "hint": {
          "en": "Pass the current measured per phase from your energy meter (e.g. P1, smart meter, Shelly EM). Load balancing calculates: available = fuse_A − grid_A per phase, then sets the charger to min(available phases) minus safety margin. For 1-phase connections, only L1 is used.",
          "nl": "Geef de per fase gemeten stroom door vanuit uw energiemeter (bijv. P1, slimme meter, Shelly EM). Laadbalancering berekent: beschikbaar = zekering_A − net_A per fase, en stelt de lader in op min(beschikbare fasen) minus veiligheidsmarge. Bij 1-fase gebruik alleen L1."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          },
          {
            "type": "number",
            "name": "current_l1",
            "placeholder": {
              "en": "L1 current (A)",
              "nl": "L1 stroom (A)"
            },
            "min": 0,
            "max": 100,
            "step": 0.1
          },
          {
            "type": "number",
            "name": "current_l2",
            "placeholder": {
              "en": "L2 current (A) — 0 if 1-phase",
              "nl": "L2 stroom (A) — 0 bij 1-fase"
            },
            "min": 0,
            "max": 100,
            "step": 0.1
          },
          {
            "type": "number",
            "name": "current_l3",
            "placeholder": {
              "en": "L3 current (A) — 0 if 1-phase",
              "nl": "L3 stroom (A) — 0 bij 1-fase"
            },
            "min": 0,
            "max": 100,
            "step": 0.1
          }
        ]
      },
      {
        "id": "set_max_current",
        "title": {
          "en": "Set maximum charge current (manual override)",
          "nl": "Stel maximale laadstroom in (handmatige override)"
        },
        "titleFormatted": {
          "en": "Set maximum charge current to [[current]] A",
          "nl": "Stel maximale laadstroom in op [[current]] A"
        },
        "hint": {
          "en": "Directly sets the Modbus max current setpoint, bypassing load balancing. The charger hardware limit from device settings still applies as upper bound.",
          "nl": "Stelt het Modbus max stroom setpoint direct in, omzeilt laadbalancering. De hardware maximale stroom uit de apparaatinstellingen geldt nog steeds als bovengrens."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          },
          {
            "type": "number",
            "name": "current",
            "placeholder": {
              "en": "Current in Ampere (6–32)",
              "nl": "Stroom in Ampère (6–32)"
            },
            "min": 6,
            "max": 32,
            "step": 1
          }
        ]
      },
      {
        "id": "set_charge_phases",
        "title": {
          "en": "Set charge phases",
          "nl": "Stel laadphases in"
        },
        "titleFormatted": {
          "en": "Set charge phases to [[phases]]",
          "nl": "Stel laadphases in op [[phases]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          },
          {
            "type": "dropdown",
            "name": "phases",
            "title": {
              "en": "Phases",
              "nl": "Fasen"
            },
            "values": [
              {
                "id": "1",
                "label": {
                  "en": "1 phase",
                  "nl": "1 fase"
                }
              },
              {
                "id": "3",
                "label": {
                  "en": "3 phases",
                  "nl": "3 fasen"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "pause_charging",
        "title": {
          "en": "Pause charging",
          "nl": "Laden pauzeren"
        },
        "titleFormatted": {
          "en": "Pause charging",
          "nl": "Laden pauzeren"
        },
        "hint": {
          "en": "Sets charge current to 3 A. The car stops drawing power but the session stays active. Load balancing is suspended while paused.",
          "nl": "Stelt laadstroom in op 3 A. De auto stopt met laden maar de sessie blijft actief. Laadbalancering is opgeschort tijdens de pauze."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          }
        ]
      },
      {
        "id": "resume_charging",
        "title": {
          "en": "Resume charging",
          "nl": "Laden hervatten"
        },
        "titleFormatted": {
          "en": "Resume charging",
          "nl": "Laden hervatten"
        },
        "hint": {
          "en": "Resumes charging at the last active setpoint. If load balancing is enabled, the optimal current is recalculated immediately.",
          "nl": "Hervat laden op het laatste actieve setpoint. Als laadbalancering is ingeschakeld, wordt de optimale stroom direct herberekend."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=alfen-ace"
          }
        ]
      }
    ]
  },
